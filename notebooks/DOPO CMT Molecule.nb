Cell[CellGroupData[{

Cell["Overlap", "Section",
 CellChangeTimes->{{3.986374095759078*^9, 3.986374096991647*^9}, {
  3.9863753136061563`*^9, 
  3.98637531445805*^9}},ExpressionUUID->"8d7445ae-beb2-4acc-9447-\
8f4a27119027"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"norm", "[", "\[Mu]_", "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], 
        RowBox[{
         RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], ")"}], "2"], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"norm", "[", "\[Mu]", "]"}], "/.", 
  RowBox[{"\[Mu]", "->", "0"}]}]}], "Input",
 CellChangeTimes->{{3.986375316538815*^9, 3.98637531767868*^9}, {
  3.986375354560597*^9, 3.986375367121777*^9}, {3.9863754072922707`*^9, 

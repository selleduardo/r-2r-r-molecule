Cell["Overlap with central supermode", "Subsubsection",
 CellChangeTimes->{{3.9532172461053457`*^9, 3.95321726135297*^9}, {
  3.9537361745729113`*^9, 
  3.9537361793451643`*^9}},ExpressionUUID->"108d8fec-e96f-4a16-aaf9-\
96d67c8afd29"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"a1", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], ";", 
  RowBox[{
   RowBox[{"\[CapitalGamma]S", "[", "\[Mu]_", "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Abs", "[", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"bS", "[", "\[Mu]", "]"}], "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 
        FractionBox["1", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
        RowBox[{
         RowBox[{"bC", "[", "0", "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]C", "[", "\[Mu]_", "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{
        RowBox[{"bC", "[", "0", "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]AS", "[", "\[Mu]_", "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"bAS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{
        RowBox[{"bC", "[", "0", "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]a1", "[", "\[Mu]_", "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{"Conjugate", "[", 
        RowBox[{"a1", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{
        RowBox[{"bC", "[", "0", "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.953735731216731*^9, 3.9537358013371716`*^9}, {

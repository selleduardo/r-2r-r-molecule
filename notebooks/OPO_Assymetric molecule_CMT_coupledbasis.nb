Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sortedEig", "[", "\[Mu]_", "]"}], ":=", 
   RowBox[{
    RowBox[{"sortedEig", "[", "\[Mu]", "]"}], "=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"vals", ",", "vecs", ",", "pairs", ",", "fixSign"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{
       "flip", " ", "sign", " ", "if", " ", "the", " ", "first", " ", 
        "component", " ", "is", " ", "negative"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"fixSign", "[", "v_", "]"}], ":=", 
        RowBox[{"v", "/", 
         RowBox[{"Sign", "[", 
          RowBox[{"v", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Re", "[", 
             RowBox[{"v", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "<", "0"}], ",", 
           RowBox[{"-", "v"}], ",", "v"}], "]"}], ";"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vals", ",", "vecs"}], "}"}], "=", 
        RowBox[{"Eigensystem", "[", 
         RowBox[{"H", "[", "\[Mu]", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"vecs", "=", 
        RowBox[{"fixSign", "/@", "vecs"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pairs", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"vals", ",", "vecs"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"SortBy", "[", 
        RowBox[{"pairs", ",", "First"}], "]"}]}]}], "]"}]}]}], ";"}]], "Input",

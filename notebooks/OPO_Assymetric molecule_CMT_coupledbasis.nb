Cell[BoxData[{
 RowBox[{
  RowBox[{"rcoupling", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Kappa]e", "->", "\[Eta]"}], " ", ",", 
     RowBox[{"\[Kappa]i", "->", 
      RowBox[{"1", "-", "\[Eta]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 

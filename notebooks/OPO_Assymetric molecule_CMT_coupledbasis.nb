        RowBox[{"\[CapitalGamma]b", "[", "0", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"3", ",", "3"}], "]"}], "]"}]}], "}"}], "/.", "rcoupling"}], 
    "//", "Evaluate"}], ",", 

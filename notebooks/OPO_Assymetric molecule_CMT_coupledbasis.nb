Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{
     "\[Mu]_", ",", "\[Delta]1_", ",", "\[Delta]2_", ",", "\[Delta]3_"}], 
     "]"}], ":=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{
         RowBox[{"bS", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bC", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bAS", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]},
       {
        RowBox[{

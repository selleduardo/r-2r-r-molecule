Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"S", "[", "\[Mu]_", "]"}], ":=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{
         RowBox[{"bS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bAS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]},
       {
        RowBox[{
         RowBox[{"bS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bAS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "2", "]"}], "]"}]},
       {
        RowBox[{
         RowBox[{"bS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "3", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "3", "]"}], "]"}], 
        RowBox[{
         RowBox[{"bAS", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "3", "]"}], "]"}]}
      }], "\[NoBreak]", ")"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Similarity", " ", "matrix"}], "*)"}], " "}]], "Input",
 CellChangeTimes->{{3.9538004000053225`*^9, 3.953800508806028*^9}},
 CellLabel->
  "In[209]:=",ExpressionUUID->"3ac741b2-1679-47c7-a446-42d38b5174f5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalGamma]", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        FractionBox[
         RowBox[{"\[Kappa]i", "+", "\[Kappa]e"}], "2"], "0", "0"},
       {"0", "\[Kappa]i", "0"},
       {"0", "0", 
        FractionBox[
         RowBox[{"\[Kappa]i", "+", "\[Kappa]e"}], "2"]}
      }], "\[NoBreak]", ")"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"Losses", " ", "in", " ", "the", " ", "uncoupled", " ", "basis"}], 
   "*)"}]}]], "Input",

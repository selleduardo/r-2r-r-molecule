       RowBox[{
        RowBox[{"bC", "[", 
         RowBox[{"0", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
         "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 

Cell[BoxData[
 RowBox[{
  RowBox[{"\[CapitalGamma]b", "[", "\[Mu]_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Inverse", "[", 
    RowBox[{"S", "[", "\[Mu]", "]"}], "]"}], ".", "\[CapitalGamma]", ".", 
   RowBox[{"S", "[", "\[Mu]", "]"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Losses", " ", "in", " ", "the", " ", "coupled", " ", "basis"}], 
    "*)"}]}]}]], "Input",

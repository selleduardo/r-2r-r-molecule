Cell["\<\
Self-overlap of C mode is equal to its overlap with the first ring:\
\>", "Text",
 CellChangeTimes->{{3.95379982570156*^9, 
  3.9537998574473476`*^9}},ExpressionUUID->"0e62a7a7-83f2-422c-b70d-\
b2cc29d95b3b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"j", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 SuperscriptBox[
  RowBox[{"Abs", "[", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"KroneckerDelta", "[", 
        RowBox[{"2", ",", "j"}], "]"}]}], ")"}]], 
    RowBox[{"Conjugate", "[", 
     RowBox[{"a1", "[", 
      RowBox[{"[", "j", "]"}], "]"}], "]"}], "*", 
    FractionBox["1", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"KroneckerDelta", "[", 
        RowBox[{"2", ",", "j"}], "]"}]}], ")"}]], 
    RowBox[{
     RowBox[{"bC", "[", "0", "]"}], "[", 
     RowBox[{"[", "j", "]"}], "]"}]}], "]"}], "2"], "\[IndentingNewLine]", 
 SuperscriptBox[
  RowBox[{"Abs", "[", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"KroneckerDelta", "[", 
        RowBox[{"2", ",", "j"}], "]"}]}], ")"}]], 
    RowBox[{"Conjugate", "[", 

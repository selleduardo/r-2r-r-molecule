Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalGamma]S", "[", 
   RowBox[{
   "\[Mu]_", ",", "\[Delta]1_", ",", "\[Delta]2_", ",", "\[Delta]3_"}], "]"}],
   ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"bS", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{
        RowBox[{"bC", "[", 
         RowBox[{"0", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
         "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]C", "[", 
   RowBox[{
   "\[Mu]_", ",", "\[Delta]1_", ",", "\[Delta]2_", ",", "\[Delta]3_"}], "]"}],
   ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"bC", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{
        RowBox[{"bC", "[", 
         RowBox[{"0", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
         "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], "]"}], "2"], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]AS", "[", 
   RowBox[{
   "\[Mu]_", ",", "\[Delta]1_", ",", "\[Delta]2_", ",", "\[Delta]3_"}], "]"}],
   ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"Abs", "[", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"KroneckerDelta", "[", 
           RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{"bAS", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], "*", 

Cell[BoxData[
 RowBox[{
  RowBox[{"RHSfunc", "[", "n_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{"\[Kappa]", "[", "n", "]"}], "2"], "+", 
       RowBox[{"\[ImaginaryI]", "\[Times]", 
        RowBox[{"\[CapitalDelta]", "[", "n", "]"}]}]}], ")"}]}], 
    RowBox[{"a", "[", "n", "]"}]}], "+", 
   RowBox[{"\[ImaginaryI]", " ", "J1", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Delta]", "[", 
        RowBox[{"n", ",", "1"}], "]"}], "*", 
       RowBox[{"a", "[", "2", "]"}]}], "+", 
      RowBox[{
       RowBox[{"\[Delta]", "[", 
        RowBox[{"n", ",", "2"}], "]"}], "*", 
       RowBox[{"a", "[", "1", "]"}]}]}], ")"}]}], "+", 
   RowBox[{"\[ImaginaryI]", " ", "J3", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Delta]", "[", 
        RowBox[{"n", ",", "2"}], "]"}], "*", 
       RowBox[{"a", "[", "3", "]"}]}], "+", 
      RowBox[{
       RowBox[{"\[Delta]", "[", 
        RowBox[{"n", ",", "3"}], "]"}], "*", 
       RowBox[{"a", "[", "2", "]"}]}]}], ")"}]}], "+", 
   RowBox[{"I", "\[Times]", 
    RowBox[{"Abs", "[", 
     RowBox[{
      RowBox[{"a", "[", "n", "]"}], "\[Times]", 
      SuperscriptBox[
       RowBox[{"a", "[", "n", "]"}], "*"]}], "]"}], "\[Times]", 
    RowBox[{"a", "[", "n", "]"}]}], "+", 
   RowBox[{
    RowBox[{"\[Delta]", "[", 
     RowBox[{"n", ",", "1"}], "]"}], "*", "s"}]}]}]], "Input",

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "q"}], " ", "-", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[CapitalDelta]", "+", 
          SuperscriptBox["q", "2"], "+", 
          SuperscriptBox["p", "2"]}], ")"}], "p"}], "+", "sq"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"-", "p"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[CapitalDelta]", "+", 
          SuperscriptBox["q", "2"], "+", 
          SuperscriptBox["p", "2"]}], ")"}], "q"}], "+", "sp"}]}], "}"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"sp", "->", "0"}], ",", 
      RowBox[{"sq", "->", "1.75"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tab", "=", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{

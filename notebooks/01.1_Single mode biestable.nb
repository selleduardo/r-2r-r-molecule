        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"eq", "/.", 
            RowBox[{"{", 
             RowBox[{"\[CapitalDelta]", "->", "det"}], "}"}]}], ")"}], "==", 
          "0"}], ",", 
         RowBox[{"{", 
          RowBox[{"q", ",", "p"}], "}"}], ",", "Reals"}], "]"}]}], "}"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"det", ",", 
       RowBox[{"-", "5"}], ",", "5", ",", "0.1"}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"2", "-", "q", "-", 
     RowBox[{"p", " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["p", "2"], "+", 
        SuperscriptBox["q", "2"], "+", "\[CapitalDelta]"}], ")"}]}]}], ",", 

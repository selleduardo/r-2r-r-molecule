
Notebook[{
Cell["Asymmetric Photonic Molecule (|oOo|) – DOPO Model","Title"],

Cell["1. Linear Hamiltonian of the 3-ring molecule","Section"],
Cell["ClearAll[\"Global`*\"]","Input"],
Cell["ω1 = ω0 - Δ; ω2 = ω0; ω3 = ω0 + Δ;","Input"],
Cell["J = J0;","Input"],
Cell["H = {{-ω1, J, 0},{J, -ω2, J},{0, J, -ω3}}; MatrixForm[H]","Input"],

Cell["2. Symmetric case |ooo|","Section"],
Cell["Δ = 0;","Input"],

Cell["3. Asymmetric case |oOo|","Section"],
Cell["Δ = Δ0;","Input"],

Cell["4. Supermode transformation","Section"],
Cell["{vals, vecs} = Eigensystem[H];","Input"],
Cell["vals","Input"],
Cell["vecs","Input"],
Cell["T = Transpose[vecs];","Input"],
Cell["T","Input"],

Cell["5. Kerr Hamiltonian in ring basis","Section"],
Cell["a = {a1,a2,a3};","Input"],
Cell["Hnl = g (Abs[a1]^4 + Abs[a2]^4 + Abs[a3]^4);","Input"],

Cell["6. Transform Kerr Hamiltonian to supermode basis","Section"],
Cell["b = {b1,b2,b3};","Input"],
Cell["aSub = Inverse[T].b","Input"],

Cell["7. Nonlinear coupling tensor gijkl","Section"],
Cell["gijkl[i_,j_,k_,l_] := g Sum[T[[r,i]] T[[r,j]] T[[r,k]] T[[r,l]], {r,1,3}]","Input"],

Cell["8. DOPO interaction coefficient (S + AS → 2C)","Section"],
Cell["gDOPO = gijkl[2,2,1,3];","Input"],
Cell["gDOPO","Input"],

Cell["9. Equations of motion","Section"],
Cell["eq1 = b1'[t] == (-κ/2 - I vals[[1]]) b1[t] + F1;","Input"],
Cell["eq2 = b2'[t] == (-κ/2 - I vals[[2]]) b2[t] - I gDOPO b1[t] b3[t] Conjugate[b2[t]];","Input"],
Cell["eq3 = b3'[t] == (-κ/2 - I vals[[3]]) b3[t] + F3;","Input"],

Cell["10. Oscillation threshold condition","Section"],
Cell["Solve[Abs[gDOPO b1 b3] == κ/2, b1]","Input"],

Cell["11. Parameter sweep vs asymmetry","Section"],
Cell["Plot[Evaluate[Abs[gijkl[2,2,1,3]]], {Δ,-5,5}]","Input"]

}]

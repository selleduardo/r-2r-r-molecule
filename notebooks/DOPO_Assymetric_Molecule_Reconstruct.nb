Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"sortedEig", "[", 
    RowBox[{
    "\[Mu]_", ",", "\[Delta]1_", ",", "\[Delta]2_", ",", "\[Delta]3_"}], 
    "]"}], ":=", 
   RowBox[{
    RowBox[{"sortedEig", "[", 
     RowBox[{"\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
     "]"}], "=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"vals", ",", "vecs", ",", "pairs", ",", "fixSign"}], "}"}], ",",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"fixSign", "[", "v_", "]"}], ":=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Re", "[", 
            RowBox[{"v", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], "<", "0"}], ",", 
          RowBox[{"-", "v"}], ",", "v"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vals", ",", "vecs"}], "}"}], "=", 
        RowBox[{"Eigensystem", "[", 
         RowBox[{"H", "[", 
          RowBox[{
          "\[Mu]", ",", "\[Delta]1", ",", "\[Delta]2", ",", "\[Delta]3"}], 
          "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"vecs", "=", 
        RowBox[{"fixSign", "/@", "vecs"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"pairs", "=", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"vals", ",", "vecs"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"SortBy", "[", 
        RowBox[{"pairs", ",", "First"}], "]"}]}]}], "]"}]}]}], ";"}]], "Input",\


Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"\[CurlyEpsilon]", "[", "1", "]"}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{"e1", " ", "-", " ", 
      RowBox[{
       SqrtBox["2"], "e2"}], " ", "+", " ", "e3"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CurlyEpsilon]", "[", "2", "]"}], "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "e1"}], " ", "+", " ", "e3"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CurlyEpsilon]", "[", "3", "]"}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{"e1", " ", "+", " ", 
      RowBox[{
       SqrtBox["2"], "e2"}], " ", "+", " ", "e3"}], ")"}]}]}], 
  ";"}]}], "Input",

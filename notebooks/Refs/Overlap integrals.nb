Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Integrand", "[", 
    RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "\[Mu]_"}], 
    "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Conjugate", "[", 
       RowBox[{"\[CurlyEpsilon]", "[", "\[Mu]", "]"}], "]"}], 
      RowBox[{"\[CurlyEpsilon]", "[", "\[Alpha]", "]"}]}], ")"}], "\[Times]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Conjugate", "[", 

Cell["Light distribution", "Subsubsection",
 CellChangeTimes->{{3.936100779058821*^9, 
  3.9361007838993387`*^9}},ExpressionUUID->"262db05b-4e85-4887-bc2b-\
02186eaa1168"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Kappa]", ",", "\[Omega]0", ",", "\[Omega]1", ",", "\[Omega]2", ",", 
   "\[Omega]3", ",", "\[CapitalOmega]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=", 
   RowBox[{"(", GridBox[{
      {"\[Omega]1", 
       RowBox[{"-", "\[Kappa]"}], "0"},
      {
       RowBox[{"-", "\[Kappa]"}], "\[Omega]2", 
       RowBox[{"-", "\[Kappa]"}]},
      {"0", 
       RowBox[{"-", "\[Kappa]"}], "\[Omega]3"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]bAS", "=", 
   RowBox[{
    RowBox[{"Eigenvalues", "[", "\[CapitalOmega]", "]"}], "[", 
    RowBox[{"[", "3", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]bC", "=", 
   RowBox[{
    RowBox[{"Eigenvalues", "[", "\[CapitalOmega]", "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]bS", "=", 
   RowBox[{
    RowBox[{"Eigenvalues", "[", "\[CapitalOmega]", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"cc72fd65-f211-4867-8285-5834045e7de1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"aAS", "=", 
   RowBox[{
    RowBox[{"Eigenvectors", "[", "\[CapitalOmega]", "]"}], "[", 
    RowBox[{"[", "3", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"aC", "=", 
   RowBox[{
    RowBox[{"Eigenvectors", "[", "\[CapitalOmega]", "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"aS", "=", 
   RowBox[{
    RowBox[{"Eigenvectors", "[", "\[CapitalOmega]", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9361008060138392`*^9, 3.9361008274468503`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"ef237302-73c8-4787-93f5-e1a803f484ef"],

Cell[CellGroupData[{

Cell[BoxData["\[Omega]bC"], "Input",
 CellLabel->"In[74]:=",ExpressionUUID->"f8d7fb54-474a-4211-a767-aa37e2544207"],

Cell[BoxData[
 RowBox[{"Root", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Kappa]", "2"], " ", "\[Omega]1"}], "+", 
     RowBox[{
      SuperscriptBox["\[Kappa]", "2"], " ", "\[Omega]3"}], "-", 
     RowBox[{"\[Omega]1", " ", "\[Omega]2", " ", "\[Omega]3"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", 
         SuperscriptBox["\[Kappa]", "2"]}], "+", 
        RowBox[{"\[Omega]1", " ", "\[Omega]2"}], "+", 
        RowBox[{"\[Omega]1", " ", "\[Omega]3"}], "+", 
        RowBox[{"\[Omega]2", " ", "\[Omega]3"}]}], ")"}], " ", "#1"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "\[Omega]1"}], "-", "\[Omega]2", "-", "\[Omega]3"}], 
       ")"}], " ", 
      SuperscriptBox["#1", "2"]}], "+", 
     SuperscriptBox["#1", "3"]}], "&"}], ",", "2"}], "]"}]], "Output",
 CellChangeTimes->{3.936109811931302*^9},
 CellLabel->"Out[74]=",ExpressionUUID->"c1aea4c5-9a21-4cbf-a846-a7bad80661d9"]
}, Open  ]],


Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rnum", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Omega]1", "->", " ", 
      RowBox[{"1.0", "+", "\[Delta]"}]}], ",", 
     RowBox[{"\[Omega]2", "->", " ", "1.0"}], ",", 
     RowBox[{"\[Omega]3", "->", " ", "1.0"}], ",", 
     RowBox[{"\[Kappa]", "->", " ", ".5"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plt0", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Omega]bAS", ",", "\[Omega]bC", ",", "\[Omega]bS"}], "}"}], 
       "/.", "rnum"}], "//", "Evaluate"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Delta]", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Black", ",", "Red"}], "}"}]}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Frequency deviation at Ring 1 (GHz)\>\"", ",", 
        "\"\<Supermode frequency, \[Omega] (GHz)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Eigenfrequencies\>\""}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<AS\>\"", ",", " ", "\"\<C\>\"", ",", " ", "\"\<S\>\""}],
          "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0.75", ",", "0.2"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plt1", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"aS", "/", 
         RowBox[{"Norm", "[", "aS", "]"}]}], ")"}], "/.", "rnum"}], "//", 
      "Evaluate"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Delta]", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Frequency deviation at Ring 1 (GHz)\>\"", ",", 
        "\"\<Uncoupled rings amplitude\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<S supermode\>\""}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<Ring 1\>\"", ",", " ", "\"\<Ring 2\>\"", ",", " ", 
          "\"\<Ring 3\>\""}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0.75", ",", "0.25"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plt2", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"aC", "/", 
         RowBox[{"Norm", "[", "aC", "]"}]}], ")"}], "/.", "rnum"}], "//", 
      "Evaluate"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Delta]", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{
       "\"\<Frequency deviation at Ring 1 (GHz)\>\"", ",", 
        "\"\<Uncoupled rings amplitude\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<C supermode\>\""}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{

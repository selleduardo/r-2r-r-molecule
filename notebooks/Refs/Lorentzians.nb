Cell[BoxData[
 RowBox[{
  RowBox[{"Spectrum", "[", 
   RowBox[{
   "x_", ",", " ", "xc_", ",", " ", "a_", ",", "N_", ",", " ", "D1_", ",", 
    "D2_"}], "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Abs", "[", "\[Mu]", "]"}], "==", "1"}], ",", "1.75", ",", 
       "1"}], "]"}], "\[Times]", 
     RowBox[{"MyLorentzian", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"xc", "+", 
        RowBox[{"\[Mu]", "*", "D1"}], "+", 
        RowBox[{"D2", "*", 
         RowBox[{
          SuperscriptBox["\[Mu]", "2"], "/", "2"}]}]}], ",", " ", "a"}], 
      "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Mu]", ",", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}]}], "/", "2"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"N", "-", "1"}], ")"}], "/", "2"}]}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9356578407580605`*^9, 3.9356579394767313`*^9}, {

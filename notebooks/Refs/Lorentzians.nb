Cell[BoxData[{
 RowBox[{
  RowBox[{"Triplet", "[", 
   RowBox[{
   "x_", ",", " ", "xc_", ",", " ", "a_", ",", " ", "J1_", ",", "Assymetry_", 
    ",", " ", "\[Mu]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"MyLorentzian", "[", 
    RowBox[{"x", ",", "xc", ",", "a"}], "]"}], " ", "+", " ", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "==", "0"}], ",", "Assymetry", ",", "1"}], "]"}], "*", 
    RowBox[{"MyLorentzian", "[", 
     RowBox[{"x", ",", 
      RowBox[{"xc", "+", "J1"}], ",", "a"}], "]"}]}], " ", "+", " ", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "==", "0"}], ",", "Assymetry", ",", "1"}], "]"}], "*", 
    RowBox[{"MyLorentzian", "[", 
     RowBox[{"x", ",", 
      RowBox[{"xc", "-", "J1"}], ",", "a"}], 
     "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Spectrum", "[", 
   RowBox[{
   "x_", ",", " ", "xc_", ",", " ", "a_", ",", " ", "J1_", ",", "Assymetry_", 
    ",", "N_", ",", " ", "D1_", ",", "D2_"}], "]"}], ":=", 
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"Triplet", "[", 
     RowBox[{"x", ",", " ", 
      RowBox[{"xc", "+", 
       RowBox[{"\[Mu]", "*", "D1"}], "+", 
       RowBox[{"D2", "*", 
        RowBox[{
         SuperscriptBox["\[Mu]", "2"], "/", "2"}]}]}], ",", " ", "a", ",", 
      " ", "J1", ",", "Assymetry", ",", " ", "\[Mu]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Mu]", ",", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"N", "-", "1"}], ")"}]}], "/", "2"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"N", "-", "1"}], ")"}], "/", "2"}]}], "}"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9356565408371277`*^9, 3.935656756007766*^9}, {

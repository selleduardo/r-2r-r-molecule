Notebook[{

Cell[CellGroupData[{
Cell["Symmetric Molecule: Resonance Detuning", "Section",
 CellChangeTimes->{{3.983867380532864*^9, 
  3.9838673916021633`*^9}},ExpressionUUID->"0656f1f2-6702-49fd-8877-\
592601a600b4"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "\[Kappa]", ",", "\[Omega]0", ",", "\[Omega]1", ",", "\[Omega]2", ",", 
   "\[Omega]3", ",", "\[CapitalOmega]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=", 
   RowBox[{"(", GridBox[{
      {"\[Omega]0", 
       RowBox[{"-", "\[Kappa]"}], "0"},
      {
       RowBox[{"-", "\[Kappa]"}], "\[Omega]1", 
       RowBox[{"-", "\[Kappa]"}]},
      {"0", 
       RowBox[{"-", "\[Kappa]"}], "\[Omega]2"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"freqs", " ", "=", " ", 
   RowBox[{"Sort", "[", 
    RowBox[{"Eigenvalues", "[", "\[CapitalOmega]", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]bS", "=", 
   RowBox[{"freqs", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]bC", "=", 
   RowBox[{"freqs", "[", 
    RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]bAS", "=", 
   RowBox[{"freqs", "[", 
    RowBox[{"[", "3", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.983865610190526*^9, 3.983865629787258*^9}, {
  3.9838660073626547`*^9, 3.983866011207406*^9}, {3.983866087604549*^9, 
  3.983866097436654*^9}, {3.983866173633665*^9, 3.983866176599934*^9}, {
  3.9838664130226793`*^9, 3.983866427048934*^9}, {3.983866512802689*^9, 
  3.983866523049892*^9}, {3.9838665551813583`*^9, 3.983866557706953*^9}, {
  3.983867122634309*^9, 3.9838671912927713`*^9}, {3.9838672341256657`*^9, 
  3.983867279013589*^9}},
 CellLabel->
  "In[134]:=",ExpressionUUID->"63b076eb-b612-46aa-ae45-01da9bffd9b2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rnum", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Omega]0", "->", " ", 
      RowBox[{"1.0", "+", "\[Delta]"}]}], ",", 
     RowBox[{"\[Omega]1", "->", " ", "1.0"}], ",", 
     RowBox[{"\[Omega]2", "->", " ", "1.0"}], ",", 
     RowBox[{"\[Kappa]", "->", " ", ".05"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Omega]bAS", "-", "\[Omega]bC"}], ",", 
       RowBox[{"\[Omega]bC", "-", "\[Omega]bC"}], ",", 
       RowBox[{"\[Omega]bS", "-", "\[Omega]bC"}]}], "}"}], "/.", "rnum"}], "//",
     "Evaluate"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Delta]", ",", 
     RowBox[{"-", "0.5"}], ",", "0.5"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9838656462913094`*^9, 3.983865680418911*^9}, {
   3.983866116744767*^9, 3.983866137269475*^9}, {3.983866192033749*^9, 

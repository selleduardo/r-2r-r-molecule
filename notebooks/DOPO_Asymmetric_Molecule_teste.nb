(* ============================================================ *)
Cell[\"8. Parametric Gain Matrix for the Central Supermode\", \"Section\"],
Cell[\"\\
Stability matrix for the degenerate signal/idler pair (both in C at \[Mu]=0):
  G = {{ -i(\[CapitalGamma]C[\[Mu]p] Pp - \[CapitalDelta]C),   i \
\[CapitalLambda]DOPO[\[Mu]p] Pp },
        { -i Conj[\[CapitalLambda]DOPO[\[Mu]p]] Pp,  \
-i(\[CapitalGamma]C[\[Mu]p] Pp - \[CapitalDelta]C) }}
Pp = normalised intracavity pump photon number, \[CapitalDelta]C = signal \
detuning.
Re[Eigenvalue] > 0 signals parametric oscillation.\", \"Text\"],

Cell[BoxData[
 RowBox[{
  RowBox[{\"GMatrixC\", \"[\",
   RowBox[{\"\[Mu]p_\", \",\", \"Pp_\", \",\", \"\[CapitalDelta]C_\"}],
  \"]\"}], \":=\",
  RowBox[{\"{\",
   RowBox[{
    RowBox[{\"{\",
     RowBox[{
      RowBox[{
       RowBox[{\"-\", \"I\"}], \" \",
       RowBox[{\"(\",
        RowBox[{
         RowBox[{RowBox[{\"\[CapitalGamma]C\", \"[\", \"\[Mu]p\", \"]\"}], \" \
\", \"Pp\"}],
         \"-\", \"\[CapitalDelta]C\"}],
       \")\"}]}], \",\",
      RowBox[{\"I\", \" \",
       RowBox[{\"\[CapitalLambda]DOPO\", \"[\", \"\[Mu]p\", \"]\"}], \" \", \
\"Pp\"}]}],
    \"}\"}], \",\",
    RowBox[{\"{\",
     RowBox[{
      RowBox[{
       RowBox[{\"-\", \"I\"}], \" \",
       RowBox[{\"Conjugate\", \"[\",
        RowBox[{\"\[CapitalLambda]DOPO\", \"[\", \"\[Mu]p\", \"]\"}],
       \"]\"}], \" \", \"Pp\"}], \",\",
      RowBox[{
       RowBox[{\"-\", \"I\"}], \" \",
       RowBox[{\"(\",
        RowBox[{
         RowBox[{RowBox[{\"\[CapitalGamma]C\", \"[\", \"\[Mu]p\", \"]\"}], \" \
\", \"Pp\"}],
         \"-\", \"\[CapitalDelta]C\"}],
       \")\"}]}]}],
    \"}\"}]}],
  \"}\"}]}]
], \"Input\", CellLabel -> \"In[17]:=\"],

Cell[BoxData[
 RowBox[{
  RowBox[{\"GainC\", \"[\",
   RowBox[{\"\[Mu]p_\", \",\", \"Pp_\", \",\", \"\[CapitalDelta]C_\"}],
  \"]\"}], \":=\",
  RowBox[{\"Max\", \"[\",
   RowBox[{\"Re\", \"[\",
    RowBox[{\"Eigenvalues\", \"[\",
     RowBox[{\"GMatrixC\", \"[\",
      RowBox[{\"\[Mu]p\", \",\", \"Pp\", \",\", \"\[CapitalDelta]C\"}],
     \"]\"}],
    \"]\"}],
   \"]\"}],
  \"]\"}]}]
], \"Input\", CellLabel -> \"In[18]:=\"],

Cell[BoxData[
 RowBox[{\"Manipulate\", \"[\",
  RowBox[{
   RowBox[{\"Plot\", \"[\",
    RowBox[{
     RowBox[{
      RowBox[{\"GainC\", \"[\", RowBox[{\"\[Mu]p\", \",\", \"Pp\", \",\", \"0\
\"}], \"]\"}],
      \"/.\", \"params\"}], \",\",
     RowBox[{\"{\", RowBox[{\"Pp\", \",\", \"0\", \",\", \"5\"}], \"}\"}], \
\",\",
     RowBox[{\"FrameLabel\", \"\[Rule]\",
      RowBox[{\"{\",
       RowBox[{\"\\\"\\<Pump power Pp\\>\\\"\", \",\", \"\\\"\\<Gain Re[\
\[Lambda]]\\>\\\"\"}],
      \"}\"}]}], \",\",
     RowBox[{\"PlotLabel\", \"\[Rule]\",
      RowBox[{\"Row\", \"[\",
       RowBox[{\"{\", RowBox[{\"\\\"\\<DOPO Gain, \[Mu]p = \\>\\\"\", \",\", \
\"\[Mu]p\"}], \"}\"}],
      \"]\"}]}], \",\",
     RowBox[{\"Frame\", \"\[Rule]\", \"True\"}], \",\",
     RowBox[{\"GridLines\", \"\[Rule]\", \"Automatic\"}], \",\",
     RowBox[{\"PlotRange\", \"\[Rule]\", \"Full\"}], \",\",
     RowBox[{\"Epilog\", \"\[Rule]\",
      RowBox[{\"{\",
       RowBox[{
        RowBox[{\"Directive\", \"[\", RowBox[{\"Dashed\", \",\", \"Gray\"}], \
\"]\"}], \",\",
        RowBox[{\"Line\", \"[\",
         RowBox[{\"{\",
          RowBox[{
           RowBox[{\"{\", RowBox[{\"0\", \",\", \"0\"}], \"}\"}], \",\",
           RowBox[{\"{\", RowBox[{\"5\", \",\", \"0\"}], \"}\"}]}],
         \"}\"}],
        \"]\"}]}],
      \"}\"}]}]}],
   \"]\"}], \",\",
   RowBox[{\"{\",
    RowBox[{
     RowBox[{\"{\", RowBox[{\"\[Mu]p\", \",\", \"1\", \",\", \"\\\"\\<Pump \
\[Mu]p\\>\\\"\"}], \"}\"}], \",\",
     \"1\", \",\", \"8\", \",\", \"1\", \",\",
     \"Appearance\", \"\[Rule]\", \"\\\"\\<Labeled\\>\\\"\"}],
   \"}\"}]}],
 \"]\"}]
], \"Input\", CellLabel -> \"In[19]:=\"],

(* ============================================================ *)
Cell[\"9. Oscillation Threshold vs. Pump Mode Index\", \"Section\"],
Cell[\"\\
At threshold (zero detuning): Pp_th = \[CapitalGamma]C[\[Mu]p] / |\
\[CapitalLambda]DOPO[\[Mu]p]|.
Minimum threshold where |\[CapitalLambda]| is large and \[CapitalGamma]C is \
small.\", \"Text\"],

Cell[BoxData[
 RowBox[{
  RowBox[{\"PpThreshold\", \"[\", \"\[Mu]p_\", \"]\"}], \":=\",
  RowBox[{
   RowBox[{\"\[CapitalGamma]C\", \"[\", \"\[Mu]p\", \"]\"}], \"/\",
   RowBox[{\"Abs\", \"[\",
    RowBox[{\"\[CapitalLambda]DOPO\", \"[\", \"\[Mu]p\", \"]\"}],
   \"]\"}]}]}]
], \"Input\", CellLabel -> \"In[20]:=\"],

Cell[BoxData[
 RowBox[{\"ListPlot\", \"[\",
  RowBox[{
   RowBox[{
    RowBox[{\"Table\", \"[\",
     RowBox[{
      RowBox[{\"{\",
       RowBox[{\"\[Mu]p\", \",\",
        RowBox[{\"PpThreshold\", \"[\", \"\[Mu]p\", \"]\"}]}],
      \"}\"}], \",\",
      RowBox[{\"{\", RowBox[{\"\[Mu]p\", \",\", \"1\", \",\", \"8\"}], \
\"}\"}]}],
    \"]\"}], \"/.\", \"params\"}], \",\",
   RowBox[{\"Joined\", \"\[Rule]\", \"True\"}], \",\",
   RowBox[{\"PlotStyle\", \"\[Rule]\",
    RowBox[{\"Directive\", \"[\",
     RowBox[{\"Blue\", \",\", RowBox[{\"PointSize\", \"[\", \"0.02\", \
\"]\"}]}],
    \"]\"}]}], \",\",
   RowBox[{\"FrameLabel\", \"\[Rule]\",
    RowBox[{\"{\",
     RowBox[{\"\\\"\\<Pump mode \[Mu]p\\>\\\"\", \",\", \"\\\"\\<Threshold \
Pp_th\\>\\\"\"}],
    \"}\"}]}], \",\",
   RowBox[{\"PlotLabel\", \"\[Rule]\", \"\\\"\\<DOPO Oscillation Threshold vs \
\[Mu]p\\>\\\"\"}], \",\",
   RowBox[{\"Frame\", \"\[Rule]\", \"True\"}], \",\",
   RowBox[{\"GridLines\", \"\[Rule]\", \"Automatic\"}]}],
 \"]\"}]
], \"Input\", CellLabel -> \"In[21]:=\"],

(* ============================================================ *)
Cell[\"10. Gain Map: Pump Power vs. Signal Detuning\", \"Section\"],
Cell[\"Oscillation tongue (Re[\[Lambda]] > 0) as a function of pump power and \
signal detuning for each \[Mu]p.\", \"Text\"],

Cell[BoxData[
 RowBox[{\"Manipulate\", \"[\",
  RowBox[{
   RowBox[{\"DensityPlot\", \"[\",
    RowBox[{
     RowBox[{
      RowBox[{\"GainC\", \"[\",

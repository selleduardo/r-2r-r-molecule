\"DotDashed\"}], \"]\"}]}],
    \"}\"}]}], \",\",
   RowBox[{\"PlotLegends\", \"\[Rule]\",
    RowBox[{\"{\",
     RowBox[{
      \"\\\"\\<\[CapitalDelta]\[Omega] S+AS\[Rule]2C\\>\\\"\", \",\",

Cell[\"11. Design Diagnostics Summary\", \"Section\"],
Cell[\"Finds the optimal pump mode \[Mu]p (minimum phase mismatch) and prints \
a full report.\", \"Text\"],

Cell[BoxData[
 RowBox[{\"Module\", \"[\",
  RowBox[{
   RowBox[{\"{\",
    RowBox[{\"muList\", \",\", \"mismatches\", \",\", \"\[Mu]pOpt\"}],
   \"}\"}], \",\",
   RowBox[{
    RowBox[{\"muList\", \"=\", RowBox[{\"Range\", \"[\", RowBox[{\"1\", \
\",\", \"8\"}], \"]\"}]}], \";\",
    RowBox[{\"mismatches\", \"=\",
     RowBox[{
      RowBox[{\"Table\", \"[\",
       RowBox[{
        RowBox[{\"Abs\", \"[\",
         RowBox[{\"\[CapitalDelta]\[Omega]DOPO\", \"[\", \"\[Mu]p\", \"]\"}],
        \"]\"}], \",\",
        RowBox[{\"{\", RowBox[{\"\[Mu]p\", \",\", \"muList\"}], \"}\"}]}],
      \"]\"}], \"/.\", \"params\"}]}], \";\",
    RowBox[{\"\[Mu]pOpt\", \"=\",
     RowBox[{\"muList\", \"\[LeftDoubleBracket]\",
      RowBox[{\"First\", \"@\",
       RowBox[{\"Ordering\", \"[\", RowBox[{\"mismatches\", \",\", \"1\"}], \
\"]\"}]}],
     \"\[RightDoubleBracket]\"}]}], \";\",
    RowBox[{\"Print\", \"[\", \"\\\"\\<=== DOPO Design Summary ===\\>\\\"\", \
\"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\", RowBox[{\"\\\"\\<Optimal pump mode \[Mu]p = \\>\\\"\", \
\",\", \"\[Mu]pOpt\"}], \"}\"}],
     \"]\"}],
    \"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\",
       RowBox[{
        \"\\\"\\<Phase mismatch \[CapitalDelta]\[Omega] = \\>\\\"\", \",\",
        RowBox[{\"N\", \"[\",
         RowBox[{
          RowBox[{\"\[CapitalDelta]\[Omega]DOPO\", \"[\", \"\[Mu]pOpt\", \
\"]\"}],
          \"/.\", \"params\"},
         \"4\"]\"}]}],
      \"}\"}],
     \"]\"}],
    \"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\",
       RowBox[{
        \"\\\"\\<FWM Overlap |\[CapitalLambda]| = \\>\\\"\", \",\",
        RowBox[{\"N\", \"[\",
         RowBox[{
          RowBox[{\"Abs\", \"[\",
           RowBox[{\"\[CapitalLambda]DOPO\", \"[\", \"\[Mu]pOpt\", \"]\"}],
          \"]\"}], \"/.\", \"params\"},
         \"4\"]\"}]}],
      \"}\"}],
     \"]\"}],
    \"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\",
       RowBox[{
        \"\\\"\\<Pump decay \[CapitalGamma]S = \\>\\\"\", \",\",
        RowBox[{\"N\", \"[\",
         RowBox[{
          RowBox[{\"\[CapitalGamma]S\", \"[\", \"\[Mu]pOpt\", \"]\"}],
          \"/.\", \"params\"},
         \"4\"]\"}]}],
      \"}\"}],
     \"]\"}],
    \"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\",
       RowBox[{
        \"\\\"\\<Signal decay \[CapitalGamma]C = \\>\\\"\", \",\",
        RowBox[{\"N\", \"[\",
         RowBox[{
          RowBox[{\"\[CapitalGamma]C\", \"[\", \"\[Mu]pOpt\", \"]\"}],
          \"/.\", \"params\"},
         \"4\"]\"}], \",\",
        \"\\\"\\< (quasi-dark)\\>\\\"\"}],
      \"}\"}],
     \"]\"}],
    \"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\",
       RowBox[{
        \"\\\"\\<AS pump decay \[CapitalGamma]AS = \\>\\\"\", \",\",
        RowBox[{\"N\", \"[\",
         RowBox[{
          RowBox[{\"\[CapitalGamma]AS\", \"[\", \"\[Mu]pOpt\", \"]\"}],
          \"/.\", \"params\"},
         \"4\"]\"}]}],
      \"}\"}],
     \"]\"}],
    \"]\"}], \";\",
    RowBox[{\"Print\", \"[\",
     RowBox[{\"Row\", \"[\",
      RowBox[{\"{\",
       RowBox[{
        \"\\\"\\<Threshold Pp_th = \\>\\\"\", \",\",

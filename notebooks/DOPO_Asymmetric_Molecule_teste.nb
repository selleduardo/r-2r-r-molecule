\"3\"}], \"}\"}], \",\",
     RowBox[{\"{\", RowBox[{\"Pp\", \",\", \"0\", \",\", \"5\"}], \"}\"}], \
\",\",
     RowBox[{\"ColorFunction\", \"\[Rule]\", \
\"\\\"\\<TemperatureMap\\>\\\"\"}], \",\",
     RowBox[{\"PlotLegends\", \"\[Rule]\", \"Automatic\"}], \",\",
     RowBox[{\"FrameLabel\", \"\[Rule]\",
      RowBox[{\"{\",
       RowBox[{\"\\\"\\<Signal detuning \[CapitalDelta]C\\>\\\"\", \",\", \
\"\\\"\\<Pump power Pp\\>\\\"\"}],
      \"}\"}]}], \",\",
     RowBox[{\"PlotLabel\", \"\[Rule]\",
      RowBox[{\"Row\", \"[\",
       RowBox[{\"{\", RowBox[{\"\\\"\\<Gain map, \[Mu]p = \\>\\\"\", \",\", \
\"\[Mu]p\"}], \"}\"}],
      \"]\"}]}]}],
   \"]\"}], \",\",
   RowBox[{\"{\",
    RowBox[{
     RowBox[{\"{\", RowBox[{\"\[Mu]p\", \",\", \"1\", \",\", \"\\\"\\<Pump \
\[Mu]p\\>\\\"\"}], \"}\"}], \",\",
     \"1\", \",\", \"8\", \",\", \"1\", \",\",
     \"Appearance\", \"\[Rule]\", \"\\\"\\<Labeled\\>\\\"\"}],
   \"}\"}]}],
 \"]\"}]
], \"Input\", CellLabel -> \"In[22]:=\"],


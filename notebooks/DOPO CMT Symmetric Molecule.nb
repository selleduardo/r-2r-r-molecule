Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"norm", "[", "\[Mu]_", "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
        RowBox[{"Conjugate", "[", 
         RowBox[{
          RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], 
        FractionBox["1", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{"2", ",", "i"}], "]"}]}], ")"}]], 
        RowBox[{
         RowBox[{"bC", "[", "\[Mu]", "]"}], "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], ")"}], "2"], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "3"}], "}"}]}], "]"}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"norm", "[", "\[Mu]", "]"}], "/.", 
  RowBox[{"\[Mu]", "->", "0"}]}]}], "Input",
 CellChangeTimes->{{3.986375316538815*^9, 3.98637531767868*^9}, {
